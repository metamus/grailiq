{
  "expo": {
    "name": "GrailIQ",
    "slug": "grailiq",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "grailiq",
    "primaryColor": "#F4C430",
    "newArchEnabled": true,
    "keywords": [
      "grading",
      "pokemon",
      "trading cards",
      "portfolio",
      "valuation",
      "sealed products"
    ],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F14"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.grailiq.app",
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.grailiq.app"
        ]
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationCategoryType": "public.app-category.finance"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F0F14"
      },
      "package": "com.grailiq.app",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/adaptive-icon.png",
          "color": "#F4C430",
          "defaultChannel": "restock-alerts"
        }
      ],
      "expo-secure-store",
      "./plugins/withNotificationServiceExtension.js",
      "./plugins/withWidgetExtension.js"
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "ed41acc9-0724-48f2-ae35-5f60c587c137"
      }
    },
    "owner": "metamus"
  }
}
